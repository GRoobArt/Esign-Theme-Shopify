
{%- capture cart_page_title -%}
  {%- content_for 'block', id: 'cart-page-title', type: '_cart-title' -%}
{%- endcapture -%}
{%- capture cart_page_items -%}
  {%- content_for 'block', id: 'cart-page-items', type: '_cart-products' -%}
{%- endcapture -%}
<cart-items-component
  class="cart-items-component"
  data-section-id="{{ section.id }}"
>
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div
    class="section color-{{ section.settings.color_scheme }} section--{{ section.settings.section_width }}"
  >
    <div
      class="cart-page spacing-style{% if cart.empty? %} cart-page--empty{% endif %}"
      style="{% render 'spacing-style', settings: section.settings %}"
    >
      <div class="cart-page__apps">
        <div class="cart-page__more-blocks">
          {%- content_for 'blocks' -%}
        </div>
      </div>

      <div class="cart-page__cart-panel">
        {%- if cart.empty? -%}
          <div class="cart-page__title">
            {{- cart_page_title -}}
          </div>

          <div class="cart-page__items">
            {{- cart_page_items -}}
          </div>
        {%- else -%}
          <div class="cart-page__items-summary-content hidden--mobile">
            <div class="cart-page__title">
              {{- cart_page_title -}}
            </div>
            <span class="cart-page__items-summary-count">
              {{ cart.item_count }}
              {{ cart.item_count | pluralize: 'producto', 'productos' }}
            </span>
          </div>

          <details class="cart-page__items-disclosure">
            <summary class="cart-page__items-summary">
              <div class="cart-page__items-summary-content">
                <div class="cart-page__title">
                  {{- cart_page_title -}}
                </div>
                <span class="cart-page__items-summary-count">
                  {{ cart.item_count }}
                  {{ cart.item_count | pluralize: 'producto', 'productos' }}
                </span>
              </div>
              <span class="svg-wrapper icon-plus">
                {{- 'icon-plus.svg' | inline_asset_content -}}
              </span>
            </summary>
          </details>

          <div class="cart-page__items-content">
            <div class="cart-page__items">
              {{- cart_page_items -}}
            </div>
          </div>
        {%- endif -%}

        {%- unless cart.empty? -%}
          <div class="cart-page__summary">
            {%- content_for 'block', id: 'cart-page-summary', type: '_cart-summary' -%}
          </div>
        {%- endunless -%}
      </div>
    </div>
  </div>
</cart-items-component>

{% stylesheet %}
  .cart-page {
    --cart-font-size--2xs: var(--font-size--2xs);
    --cart-font-size--xs: var(--font-size--xs);
    --cart-font-size--sm: var(--font-size--sm);
    --cart-font-size--md: var(--font-size--md);
    --cart-font-size--2xl: var(--font-size--2xl);

    display: grid;
    grid-template-columns: 1fr;
    gap: var(--padding-5xl);
  }

  .cart-page__apps,
  .cart-page__cart-panel,
  .cart-page__more-blocks,
  .cart-page__items-disclosure,
  .cart-page__items-summary-content,
  .cart-page__items-content,
  .cart-page__title,
  .cart-page__items,
  .cart-page__summary {
    width: 100%;
    min-width: 0;
  }

  .cart-page__cart-panel {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
  }

  .cart-page__summary {
    display: grid;
    grid-template-rows: auto;
  }

  .cart-page__items-disclosure {
    display: flex;
    flex-direction: column;
  }

  .cart-page__items-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-sm);
    padding-inline: var(--padding-xs); 
  }

  .cart-page__items-summary::-webkit-details-marker {
    display: none;
  }

  .cart-page__items-summary-count {
    display: block;
  }

  .cart-page__items-summary .icon-plus svg {
    width: var(--icon-size-xs);
    aspect-ratio: 1;
  }

  .cart-page__title--desktop,
  .cart-page__items-content {
    display: none;
  }

  .cart-page__items-disclosure[open] + .cart-page__items-content {
    display: block;
  }

  .cart-page__items-disclosure[open] .cart-page__items-summary .horizontal {
    rotate: 90deg;
  }

  .cart-page__more-blocks {
    display: flex;
    flex-direction: column;
    gap: var(--padding-xl);
  }

  .cart-page--empty .cart-title {
    text-align: center;
  }

  .cart-page--empty .cart-page__cart-panel {
    align-items: center;
  }

  .cart-page--empty .cart-page__title,
  .cart-page--empty .cart-page__items {
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .cart-page {
      gap: var(--padding-2xl);
    }
  }

  @media screen and (min-width: 750px) {
    .cart-page__title--desktop,
    .cart-page__items-content {
      display: block;
    }

    .cart-page__items-disclosure {
      display: none;
    }

    .cart-page {
      grid-template-columns: minmax(0, 1fr) min(50vw, var(--sidebar-width));
      align-items: start;
    }

    .cart-page__apps {
      grid-column: 1;
    }

    .cart-page__cart-panel {
      grid-column: 2;
    }

    .section--page-width .cart-page:has(.cart__container--extend) {
      grid-template-columns: minmax(0, 1fr) minmax(
          var(--sidebar-width),
          calc((100vw - var(--page-width)) / 2 + var(--sidebar-width))
        );
    }
  }

  @media screen and (min-width: 1400px) {
    .cart-page {
      grid-template-columns: minmax(0, 1fr) var(--sidebar-width);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.cart",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "button"
    },
    {
      "type": "video"
    },
    {
      "type": "group"
    },
    {
      "type": "spacer"
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
